---
import Card from "./Card/index.astro";
import { Image } from "astro:assets";

// TODO: Replace these placeholder paths once you drop your new images into src/assets/
import CropDocImg from "../assets/illustrations/hex_element.png"; 
import ExplainableAIImg from "../assets/illustrations/stock_market_up.webp";
import EduAgentImg from "../assets/illustrations/remote_control.webp";
import AffectiveRecsImg from "../assets/illustrations/prospective.webp";
---

<Card
  colSpan="lg:col-span-1"
  rowSpan="md:row-span-1"
  title="Project Lab"
  href="/projects"
>
  <div
    class="absolute inset-0 z-[-1] opacity-20 grid grid-cols-[repeat(4,2.5rem)] grid-rows-[repeat(3,2.5rem)] gap-2 rotate-40 w-fit"
  >
    {/* Row 1 */}
    <Image
      src={CropDocImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="CropDoc project preview"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={ExplainableAIImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="Explainable AI visualization"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={EduAgentImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="EduAgent system architecture"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={AffectiveRecsImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="Affective recommendation system capture"
      loading="eager"
      decoding="auto"
    />

    {/* Row 2 */}
    <Image
      src={ExplainableAIImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="Explainable AI visualization"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={CropDocImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="CropDoc project preview"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={AffectiveRecsImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="Affective recommendation system capture"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={EduAgentImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="EduAgent system architecture"
      loading="eager"
      decoding="auto"
    />

    {/* Row 3 */}
    <Image
      src={EduAgentImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="EduAgent system architecture"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={AffectiveRecsImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="Affective recommendation system capture"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={CropDocImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="CropDoc project preview"
      loading="eager"
      decoding="auto"
    />
    <Image
      src={ExplainableAIImg}
      class="w-10 h-10 rounded-md object-cover"
      alt="Explainable AI visualization"
      loading="eager"
      decoding="auto"
    />
  </div>
</Card>
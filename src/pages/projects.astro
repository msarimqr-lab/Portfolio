---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../site-config";

// --- CROP DOC IMAGE IMPORTS ---
import PaanAI from "../assets/illustrations/AI PAAN .jpeg";
import PaanArticle from "../assets/illustrations/Article.jpeg";
import PaanEnglishLogin from "../assets/illustrations/ENGLISH LOGIN.jpeg";
import PaanExpertForm from "../assets/illustrations/EXPERT FORM (1).jpeg";
import PaanExpertUrdu from "../assets/illustrations/EXPERT FORM URDU.jpeg";
import PaanHome from "../assets/illustrations/HOME PAGE.jpeg";
import PaanMarket from "../assets/illustrations/MARKET PLACE.jpeg";
import PaanEncyclopedia from "../assets/illustrations/PLANT ENCYCLOPEDIA.jpeg";
import PaanUrduLogin from "../assets/illustrations/URDU LOGIN.jpeg";

// Framework Stand-in Visuals for other sections
import ExplainableAIPlot from "../assets/illustrations/stock_market_up.webp";
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Project Lab`}
  description="A breakdown of my engineered architectures, deep learning models, and automated production pipelines."
>
  <main class="mx-auto max-w-6xl w-full p-6 pt-32 text-neutral-100 flex flex-col gap-16 overflow-x-hidden">
    <a
      href="/"
      class="fixed top-10 left-10 text-white bg-neutral-900 hover:bg-neutral-800 w-fit px-4 py-2 border border-solid border-neutral-600 rounded-lg z-50 transition-all hover:scale-105"
      >Back</a
    >

    <div>
      <h1 class="text-4xl font-black uppercase text-white tracking-wider m-0">Project Lab</h1>
      <p class="text-sm font-light text-neutral-400 mt-2 max-w-2xl">
        Production architectures, deep neural networks, and interactive automation ecosystems engineered to solve target industry problems.
      </p>
    </div>

    {/* PROJECT MODULE 1: CROPDOC */}
    <section class="border-t border-neutral-800 pt-8">
      <div class="mb-6">
        <span class="text-xs font-mono uppercase px-2 py-1 bg-emerald-950 text-emerald-400 rounded-md border border-emerald-800">Computer Vision Ecosystem</span>
        <h2 class="text-2xl font-bold mt-3 text-white">CropDoc: Intelligent Betel Leaf Diagnostic & Agritech Platform</h2>
        <p class="text-sm font-light text-neutral-400 mt-1 max-w-4xl">
          An end-to-end mobile agritech application integrating specialized Convolutional Neural Networks (CNNs) for plant disease screening, localized weather forecasting trackers, native Urdu language pipelines, and a regional trade business marketplace.
        </p>
      </div>

      {/* --- EYE CATCHING INFINITE MARQUEE SLIDER --- */}
      <div class="w-full overflow-hidden relative py-8 mask-edges">
        <div class="flex gap-6 w-max animate-marquee hover:[animation-play-state:paused]">
          
          {/* Track 1: Original Set of Screens */}
          {[
            { img: PaanHome, title: "Home Weather Feed" },
            { img: PaanAI, title: "AI Diagnostician" },
            { img: PaanExpertUrdu, title: "Urdu Diagnostics" },
            { img: PaanMarket, title: "E-Commerce Market" },
            { img: PaanExpertForm, title: "Community Forum" },
            { img: PaanEncyclopedia, title: "Paan Encyclopedia" },
            { img: PaanArticle, title: "Technical Handbook" },
            { img: PaanUrduLogin, title: "Urdu Access Profile" },
            { img: PaanEnglishLogin, title: "English Gateway" }
          ].map((screen) => (
            <div class="w-[220px] flex-none group relative bg-neutral-900/40 border border-neutral-800/80 p-3 rounded-2xl flex flex-col gap-3 transition-all duration-300 ease-out hover:-translate-y-3 hover:border-emerald-500/50 hover:bg-neutral-900/80 hover:shadow-[0_10px_30px_rgba(16,185,129,0.2)]">
              <div class="w-full overflow-hidden rounded-xl bg-neutral-950 aspect-[9/19] flex items-center justify-center relative">
                <Image src={screen.img} class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" alt={screen.title} />
                <div class="absolute inset-0 bg-gradient-to-tr from-emerald-500/0 via-white/5 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
              </div>
              <p class="text-xs font-semibold text-neutral-400 group-hover:text-emerald-400 transition-colors duration-300 px-1 text-center m-0">{screen.title}</p>
            </div>
          ))}

          {/* Track 2: Exact Duplicate for Infinite Seamless Loop Effect */}
          {[
            { img: PaanHome, title: "Home Weather Feed" },
            { img: PaanAI, title: "AI Diagnostician" },
            { img: PaanExpertUrdu, title: "Urdu Diagnostics" },
            { img: PaanMarket, title: "E-Commerce Market" },
            { img: PaanExpertForm, title: "Community Forum" },
            { img: PaanEncyclopedia, title: "Paan Encyclopedia" },
            { img: PaanArticle, title: "Technical Handbook" },
            { img: PaanUrduLogin, title: "Urdu Access Profile" },
            { img: PaanEnglishLogin, title: "English Gateway" }
          ].map((screen) => (
            <div class="w-[220px] flex-none group relative bg-neutral-900/40 border border-neutral-800/80 p-3 rounded-2xl flex flex-col gap-3 transition-all duration-300 ease-out hover:-translate-y-3 hover:border-emerald-500/50 hover:bg-neutral-900/80 hover:shadow-[0_10px_30px_rgba(16,185,129,0.2)]">
              <div class="w-full overflow-hidden rounded-xl bg-neutral-950 aspect-[9/19] flex items-center justify-center relative">
                <Image src={screen.img} class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" alt={screen.title} />
                <div class="absolute inset-0 bg-gradient-to-tr from-emerald-500/0 via-white/5 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
              </div>
              <p class="text-xs font-semibold text-neutral-400 group-hover:text-emerald-400 transition-colors duration-300 px-1 text-center m-0">{screen.title}</p>
            </div>
          ))}

        </div>
      </div>
      <div class="flex justify-end gap-2 text-[10px] font-mono text-neutral-500 px-2 uppercase tracking-widest mt-2">
        <span>Hover to Pause • Scroll to Intercept</span>
      </div>
    </section>

    {/* PROJECT MODULE 2: EXPLAINABLE AI */}
    <section class="border-t border-neutral-800 pt-8 mb-12">
      <div class="mb-6">
        <span class="text-xs font-mono uppercase px-2 py-1 bg-blue-950 text-blue-400 rounded-md border border-blue-800">Model Interpretability</span>
        <h2 class="text-2xl font-bold mt-3 text-white">Explainable AI (XAI) Medical Diagnostic Engine</h2>
        <p class="text-sm font-light text-neutral-400 mt-1 max-w-4xl">
          An analytical forecasting panel predicting cardiovascular vulnerabilities incorporating SHAP value calculations and localized additive LIME feature dependencies.
        </p>
      </div>

      <div class="group relative bg-neutral-900/40 border border-neutral-800 p-4 rounded-2xl flex flex-col gap-2 max-w-xl transition-all duration-300 hover:-translate-y-2 hover:border-blue-500/50 hover:shadow-[0_10px_30px_rgba(59,130,246,0.15)]">
        <div class="w-full h-48 overflow-hidden rounded-xl bg-neutral-950">
          <Image src={ExplainableAIPlot} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-500 group-hover:scale-102" alt="SHAP Beeswarm Interpretability Array" />
        </div>
        <p class="text-xs font-medium text-neutral-400 group-hover:text-blue-400 transition-colors duration-300 mt-1 m-0">Feature Attribution Map Component</p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Infinite Marquee Linear Animation Sequence */
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 12px)); /* Matches gap calculation perfectly */
    }
  }

  .animate-marquee {
    animation: marquee 30s linear infinite;
  }

  /* Elegant side-fading mask overlay so screens blend smoothly into borders */
  .mask-edges {
    background: transparent;
    mask-image: linear-gradient(to right, transparent, white 8%, white 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 8%, white 92%, transparent);
  }
</style>
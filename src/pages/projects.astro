---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../site-config";

// --- CROP DOC IMAGE IMPORTS ---
import PaanAI from "../assets/illustrations/AI PAAN .jpeg";
import PaanArticle from "../assets/illustrations/Article.jpeg";
import PaanEnglishLogin from "../assets/illustrations/ENGLISH LOGIN.jpeg";
import PaanExpertForm from "../assets/illustrations/EXPERT FORM (1).jpeg";
import PaanExpertUrdu from "../assets/illustrations/EXPERT FORM URDU.jpeg";
import PaanHome from "../assets/illustrations/HOME PAGE.jpeg";
import PaanMarket from "../assets/illustrations/MARKET PLACE.jpeg";
import PaanEncyclopedia from "../assets/illustrations/PLANT ENCYCLOPEDIA.jpeg";
import PaanUrduLogin from "../assets/illustrations/URDU LOGIN.jpeg";

// --- EXPLAINABLE AI (XAI) IMAGE IMPORTS ---
import XaiLogin from "../assets/illustrations/xai-login.png";
import XaiBiomarkers from "../assets/illustrations/xai-biomarkers.png";
import XaiCalendar from "../assets/illustrations/xai-calendar-ui.png";
import XaiGauge from "../assets/illustrations/xai-gauge-metrics.png";
import XaiShap from "../assets/illustrations/xai-shap-analysis.png";
import XaiLime from "../assets/illustrations/xai-lime-details.png";
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";

  animate([loaderAnimation] as AnimationSequence);

  // --- INTERACTIVE AMBIENT GLOW & TEXT REVEAL ENGINE ---
  const sections = document.querySelectorAll(".scroll-section");
  const progressBar = document.getElementById("timeline-progress");

  const observerOptions = {
    root: null,
    rootMargin: "-25% 0px -45% 0px",
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("is-active");
      }
    });
  }, observerOptions);

  sections.forEach((section) => observer.observe(section));

  // --- SMOOTH PROGRESS PIPELINE TRACKER ---
  window.addEventListener("scroll", () => {
    const duration = document.documentElement.scrollHeight - window.innerHeight;
    const scrolled = (window.scrollY / duration) * 100;
    if (progressBar) {
      progressBar.style.height = `${scrolled}%`;
    }
  });
</script>

<Layout

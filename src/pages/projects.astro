</Layout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 12px)); }
  }
  .animate-marquee { animation: marquee 35s linear infinite; }
  .animate-marquee-slow { animation: marquee 45s linear infinite; }

  .mask-edges {
    background: transparent;
    mask-image: linear-gradient(to right, transparent, white 8%, white 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 8%, white 92%, transparent);
  }

  /* --- SCROLL REVEAL --- */
  .reveal-element {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .reveal-element.delay-1 { transition-delay: 150ms; }
  .scroll-section.is-active .reveal-element { opacity: 1; transform: translateY(0); }

  body:has(.custom-section-cropdoc.is-active) .layer-glow-cropdoc { opacity: 1; }
  body:has(.custom-section-xai.is-active) .layer-glow-xai { opacity: 1; }

  /* --- NEON BACKGROUND LIGHT BEAMS (LASERS) --- */
  .laser-v {
    position: absolute;
    top: -150px;
    width: 1px;
    height: 120px;
    background: linear-gradient(to bottom, transparent, #10b981, transparent);
    box-shadow: 0 0 8px #10b981;
    opacity: 0.3;
    animation: fall 6s linear infinite;
  }
  .laser-v-1 { left: 15%; animation-delay: 0s; animation-duration: 7s; }
  .laser-v-2 { left: 45%; background: linear-gradient(to bottom, transparent, #3b82f6, transparent); box-shadow: 0 0 8px #3b82f6; animation-delay: 2s; animation-duration: 9s; }
  .laser-v-3 { left: 80%; animation-delay: 4.5s; animation-duration: 6.5s; }

  .laser-h {
    position: absolute;
    left: -150px;
    height: 1px;
    width: 120px;
    background: linear-gradient(to right, transparent, #14b8a6, transparent);
    box-shadow: 0 0 8px #14b8a6;
    opacity: 0.25;
    animation: shoot 8s linear infinite;
  }
  .laser-h-1 { top: 25%; animation-delay: 1s; animation-duration: 8s; }
  .laser-h-2 { top: 65%; background: linear-gradient(to right, transparent, #8b5cf6, transparent); box-shadow: 0 0 8px #8b5cf6; animation-delay: 4s; animation-duration: 11s; }

  @keyframes fall {
    0% { transform: translateY(0); opacity: 0; }
    10% { opacity: 0.4; }
    90% { opacity: 0.4; }
    100% { transform: translateY(calc(100vh + 200px)); opacity: 0; }
  }

  @keyframes shoot {
    0% { transform: translateX(0); opacity: 0; }
    10% { opacity: 0.35; }
    90% { opacity: 0.35; }
    100% { transform: translateX(calc(100vw + 200px)); opacity: 0; }
  }
</style>